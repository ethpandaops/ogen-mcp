	data, err := json.Marshal(value)
	if err != nil {
		return nil, fmt.Errorf("encoding tool result: %w", err)
	}

	text := string(data)
	if maxBytes > 0 && len(text) > maxBytes {
		text = text[:maxBytes]
	}

	return &mcp.CallToolResult{
		Content: []mcp.Content{
			&mcp.TextContent{Text: text},
		},
	}, nil
}

